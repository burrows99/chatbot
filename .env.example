# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/chatbot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=chatbot

# https://vercel.com/docs/redis
REDIS_URL=redis://localhost:6379

# https://hub.docker.com/r/minio/minio
MINIO_ROOT_USER=****
MINIO_ROOT_PASSWORD=****
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=chatbot

# https://ai-sdk.dev/providers/community-providers/ollama
OLLAMA_BASE_URL=http://localhost:11434
# https://docs.ollama.com/cloud — create a key at https://ollama.com/settings/keys
OLLAMA_API_KEY=

# Mapped names that mcp-atlassian container reads (loaded via env_file in docker-compose)
ATLASSIAN_OAUTH_CLIENT_ID=
ATLASSIAN_OAUTH_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=

# MCP server URLs — NEXT_PUBLIC_ so they're inlined into the client bundle for DEFAULT_MCP_CONFIG
NEXT_PUBLIC_GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
NEXT_PUBLIC_ATLASSIAN_MCP_URL=http://localhost:8888/mcp
NEXT_PUBLIC_PLANNER_MCP_URL=http://localhost:8000/mcp
